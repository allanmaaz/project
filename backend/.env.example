APP_ENV=development
DEBUG=True

# ── Supabase ──────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here

# ── Database (Supabase PostgreSQL direct connection) ──
DATABASE_URL=postgresql+asyncpg://postgres:your_password@db.your-project.supabase.co:5432/postgres

# ── AI (FREE — get from https://aistudio.google.com/app/apikey) ──
GEMINI_API_KEY=your_free_gemini_api_key_here

# ── App Limits ──
MAX_FILE_SIZE_MB=20
MAX_PDF_SIZE_MB=50
FREE_PLAN_MONTHLY_UPLOADS=10

# ── Sentry (optional, free tier) ──
SENTRY_DSN=

# ── CORS ──
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
